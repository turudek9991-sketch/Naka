<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Screen Scroll Konsol Terminal -->
    <ScrollView
        android:id="@+id/terminal_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#020205"
        android:padding="8dp">

        <TextView
            android:id="@+id/terminal_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FFCC" />
    </ScrollView>

    <!-- Panel Input Terminal Interaktif -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:background="#12121A"
        android:padding="4dp">

        <EditText
            android:id="@+id/terminal_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:fontFamily="monospace"
            android:hint="Ketik perintah..."
            android:inputType="text"
            android:maxLines="1"
            android:padding="10dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#505070"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_terminal_enter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#00FFCC"
            android:text="ENTER"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
