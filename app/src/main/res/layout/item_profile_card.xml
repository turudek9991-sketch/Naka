<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_profile_card">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/profile_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profil 1 · com.roblox.client"
            android:textColor="@color/text_white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_remove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/red"
            android:textSize="18sp"
            android:paddingHorizontal="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Cookie input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cookie (.ROBLOSECURITY)"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

    <EditText
        android:id="@+id/input_cookie"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="_|WARNING:-DO-NOT-SHARE..."
        android:background="@drawable/bg_input"
        android:textColor="@color/text_white"
        android:textColorHint="@color/text_dim"
        android:textSize="13sp"
        android:padding="10dp"
        android:inputType="textPassword"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp" />

    <!-- Link input -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Link Server (opsional)"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

    <EditText
        android:id="@+id/input_link"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="roblox://placeID=..."
        android:background="@drawable/bg_input"
        android:textColor="@color/text_white"
        android:textColorHint="@color/text_dim"
        android:textSize="13sp"
        android:padding="10dp"
        android:inputType="textUri"
        android:layout_marginTop="4dp" />

</LinearLayout>
