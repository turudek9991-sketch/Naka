<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Baca semua package yang terinstall (deteksi clone Roblox) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <!-- Cek proses yang sedang berjalan -->
    <uses-permission android:name="android.permission.GET_TASKS" />
    <!-- Foreground service biar DHub tetap jalan di background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Wake lock biar tidak sleep -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- Internet untuk Discord webhook -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Restart app lain -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="DHub"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.DHub"
        android:largeHeap="true">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground Service untuk monitoring background -->
        <service
            android:name=".MonitorService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
